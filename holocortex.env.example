# Holocortex site configuration — SINGLE documented source for every variable.
# Per host: copy to ~/.config/holocortex/env and edit (clients: hcr/hca/hcd).
# Router container: copy to scripts/router/router.env (gitignored — G5).
# Precedence everywhere: process env > config file > localhost fallback.

## Inference backends (shared by router daemon, hca, hcd)
HCR_OLLAMA_PRIMARY=http://gpu-host.example:11434
HCR_OLLAMA_FALLBACK=http://fallback-host.example:11434   # empty/omit = no fallback

## Router daemon
HCR_REFLEX_MODEL=gemma4:latest
HCR_PLANNER_MODEL=claude-sonnet-5
HCR_ANTHROPIC_API_KEY=
HCR_BUDGET_TOKENS_DAY=200000
HCR_REFLEX_CTX_CHARS=12000
HCR_COMPLEXITY_CHARS=1500
HCR_TOOLING_KEYWORDS="mcp,netbox,wake-on-lan,wol,container,jira,confluence,home assistant"
HCR_LOG_FILE=/data/routing.jsonl
HCR_PORT=8377
HCR_TIMEOUT_S=300

## Clients
HCR_ROUTER_URL=http://router-host.example:8377
HCR_AUTH_TOKEN=          # optional; set same value in router.env to require X-HC-Token

## Auditor (hca) — model pinned by eval baseline; override deliberately
HCA_AUDITOR_MODEL=gemma4:latest
HCA_TIMEOUT_S=300

## Capture drafter (hcd)
HCD_MODEL=gemma4:latest
HCD_TIMEOUT_S=300
